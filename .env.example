# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Required — powers the AI assistant (FIT Asistan)
# Get from: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — add when owner decides on payment provider
# iyzico (Turkish payment)
# VITE_IYZICO_API_KEY=your_iyzico_api_key
# VITE_IYZICO_SECRET_KEY=your_iyzico_secret_key

# Stripe (International)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
